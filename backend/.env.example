# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://transitops_user:changeme@localhost:5432/transitops_db

# ─── Auth / Security ────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-secret
